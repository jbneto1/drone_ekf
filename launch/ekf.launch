<?xml version="1.0"?>
<launch>
    <!--
        Main EKF launch.
        Edit config/ekf_params.yaml for runtime choices such as /use_sim_time,
        controller topic defaults, diagnostics settings, and EKF parameters.
    -->
    <rosparam command="load" file="$(find drone_ekf)/config/ekf_params.yaml" subst_value="true"/>

    <node name="drone_ekf" pkg="drone_ekf" type="ekf_node.py" output="screen">
        <param name="config_file" value="$(find drone_ekf)/config/ekf_params.yaml"/>
    </node>

    <node name="controller_frame_diagnostics" pkg="drone_ekf" type="controller_frame_diagnostics.py" output="screen">
        <param name="config_file" value="$(find drone_ekf)/config/ekf_params.yaml"/>
    </node>
</launch>
